@{
    ViewData["Title"] = "daenet QR Studio";
}

<main class="app">

    <!-- ── Sidebar ── -->
    <section class="panel--left">

        <div class="sidebar-header">
            <header class="brand">
                <div class="brand__icon">
                    <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
                        <!-- QR finder patterns -->
                        <rect x="2" y="2" width="12" height="12" rx="2.5" fill="currentColor"/>
                        <rect x="18" y="2" width="12" height="12" rx="2.5" fill="currentColor"/>
                        <rect x="2" y="18" width="12" height="12" rx="2.5" fill="currentColor"/>
                        <!-- daenet triangle accent in bottom-right quadrant -->
                        <polygon points="19,18 30,30 19,30" fill="currentColor" opacity=".85"/>
                        <rect x="25" y="18" width="5" height="5" rx="1" fill="currentColor"/>
                        <!-- Finder eyes -->
                        <rect x="5.5" y="5.5" width="5" height="5" rx=".75" fill="var(--surface)"/>
                        <rect x="21.5" y="5.5" width="5" height="5" rx=".75" fill="var(--surface)"/>
                        <rect x="5.5" y="21.5" width="5" height="5" rx=".75" fill="var(--surface)"/>
                    </svg>
                </div>
                <span class="brand__name">daenet <em>QR Studio</em></span>
            </header>
        </div>

        <div class="sidebar-body">

            <!-- Mode selector -->
            <div class="mode-selector">
                <input type="radio" id="mode-url" name="qr-mode" value="url" checked hidden />
                <label for="mode-url" class="mode-selector__option mode-selector__option--active">URL</label>
                <input type="radio" id="mode-contact" name="qr-mode" value="contact" hidden />
                <label for="mode-contact" class="mode-selector__option">Contact</label>
            </div>

            <!-- URL block -->
            <div class="url-block">
                <p class="section-label">Content</p>
                <div class="field-group">
                    <label class="field-label" for="qr-content">URL</label>
                    <div class="input-row">
                        <input
                            id="qr-content"
                            type="text"
                            class="input"
                            placeholder="https://example.com"
                            autocomplete="off"
                            spellcheck="false" />
                        <button class="btn btn--primary" id="generate-btn" aria-label="Generate QR code" title="Generate QR code">
                            <span class="btn__icon">
                                <svg width="16" height="16" viewBox="0 0 32 32" fill="none">
                                    <rect x="2" y="2" width="12" height="12" rx="2" fill="currentColor"/>
                                    <rect x="18" y="2" width="12" height="12" rx="2" fill="currentColor"/>
                                    <rect x="2" y="18" width="12" height="12" rx="2" fill="currentColor"/>
                                    <rect x="18" y="18" width="5" height="5" rx="1" fill="currentColor"/>
                                    <rect x="25" y="18" width="5" height="5" rx="1" fill="currentColor"/>
                                    <rect x="18" y="25" width="5" height="5" rx="1" fill="currentColor"/>
                                    <rect x="25" y="25" width="5" height="5" rx="1" fill="currentColor"/>
                                    <rect x="5" y="5" width="6" height="6" rx="1" fill="var(--accent-fg)"/>
                                    <rect x="21" y="5" width="6" height="6" rx="1" fill="var(--accent-fg)"/>
                                    <rect x="5" y="21" width="6" height="6" rx="1" fill="var(--accent-fg)"/>
                                </svg>
                            </span>
                            <span class="btn__spinner" hidden>
                                <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                                    <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="2"
                                        stroke-dasharray="28" stroke-dashoffset="10" stroke-linecap="round"/>
                                </svg>
                            </span>
                        </button>
                    </div>
                    <p class="field-error" id="content-error" hidden></p>
                </div>
            </div>

            <!-- Contact block -->
            <div class="contact-block" hidden>
                <!-- Contact actions: Upload + Open Existing -->
                <div class="contact-actions">
                    <button class="btn btn--outline" id="upload-contact-btn">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                            <polyline points="17 8 12 3 7 8"/>
                            <line x1="12" y1="3" x2="12" y2="15"/>
                        </svg>
                        Upload
                    </button>
                    <button class="btn btn--outline" id="open-existing-btn">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
                        </svg>
                        Open Existing
                    </button>
                    <span class="info-icon" title="You can open existing contact card — provide first name, last name and access code">ⓘ</span>
                    <input type="file" id="upload-contact-file" accept=".txt,.json" class="upload-file-input" style="position:absolute;opacity:0;pointer-events:none;" />
                    <p class="field-error" id="upload-contact-error" hidden></p>
                </div>

                <p class="section-label">Content</p>

                <!-- Photo upload -->
                <div class="photo-upload" id="photo-upload-zone">
                    <div class="photo-upload__placeholder" id="photo-placeholder">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                        <span>Add photo</span>
                    </div>
                    <img class="photo-upload__preview" id="photo-preview" alt="Photo preview" hidden />
                    <button class="photo-upload__remove" id="remove-photo" hidden title="Remove photo">&times;</button>
                    <input type="file" id="photo-file" accept="image/png,image/jpeg,image/webp" class="upload-file-input" />
                </div>
                <div class="photo-upload__options" id="photo-options" hidden>
                    <label class="photo-upload__checkbox-label">
                        <input type="checkbox" id="include-photo" checked />
                        Include photo in QR code
                    </label>
                </div>
                <p class="field-error" id="photo-error" hidden></p>

                <div class="field-row">
                    <div class="field-group field-group--half">
                        <label class="field-label" for="contact-first-name">First Name</label>
                        <input id="contact-first-name" type="text" class="input" placeholder="Jane" autocomplete="off" />
                        <p class="field-error" id="first-name-error" hidden></p>
                    </div>
                    <div class="field-group field-group--half">
                        <label class="field-label" for="contact-last-name">Last Name</label>
                        <input id="contact-last-name" type="text" class="input" placeholder="Doe" autocomplete="off" />
                        <p class="field-error" id="last-name-error" hidden></p>
                    </div>
                </div>
                <div class="field-group">
                    <label class="field-label" for="contact-phone">Phone</label>
                    <input id="contact-phone" type="tel" class="input" placeholder="+49 123 456 7890" autocomplete="off" />
                    <p class="field-error" id="phone-error" hidden></p>
                </div>
                <div class="field-group">
                    <label class="field-label" for="contact-email">Email</label>
                    <input id="contact-email" type="email" class="input" placeholder="jane@example.com" autocomplete="off" />
                    <p class="field-error" id="email-error" hidden></p>
                </div>
                <div class="field-group">
                    <label class="field-label" for="contact-org">Organisation</label>
                    <input id="contact-org" type="text" class="input" placeholder="Acme Corp" autocomplete="off" />
                </div>
                <div class="field-group">
                    <label class="field-label" for="contact-title">Job Title</label>
                    <input id="contact-title" type="text" class="input" placeholder="Software Engineer" autocomplete="off" />
                </div>
                <div class="field-group">
                    <label class="field-label" for="contact-website">Website</label>
                    <input id="contact-website" type="url" class="input" placeholder="https://example.com" autocomplete="off" />
                </div>
                <button class="btn btn--primary btn--full-width" id="generate-contact-btn" aria-label="Generate contact QR code">Generate</button>
                <p class="field-error" id="vcard-length-error" hidden></p>

                <!-- Social Media section -->
                <div class="social-media-block">
                    <p class="section-label">Social Media</p>
                    <div class="social-fields">
                        <div class="social-field" data-platform="LinkedIn">
                            <label class="social-checkbox-label">
                                <input type="checkbox" class="social-checkbox" data-platform="LinkedIn" />
                                <span class="social-platform-name">LinkedIn</span>
                            </label>
                            <input type="url" class="input social-url" data-platform="LinkedIn" placeholder="https://linkedin.com/in/yourname" autocomplete="off" />
                            <p class="field-error social-url-error" hidden></p>
                        </div>
                        <div class="social-field" data-platform="Instagram">
                            <label class="social-checkbox-label">
                                <input type="checkbox" class="social-checkbox" data-platform="Instagram" />
                                <span class="social-platform-name">Instagram</span>
                            </label>
                            <input type="url" class="input social-url" data-platform="Instagram" placeholder="https://instagram.com/yourname" autocomplete="off" />
                            <p class="field-error social-url-error" hidden></p>
                        </div>
                        <div class="social-field" data-platform="Facebook">
                            <label class="social-checkbox-label">
                                <input type="checkbox" class="social-checkbox" data-platform="Facebook" />
                                <span class="social-platform-name">Facebook</span>
                            </label>
                            <input type="url" class="input social-url" data-platform="Facebook" placeholder="https://facebook.com/yourname" autocomplete="off" />
                            <p class="field-error social-url-error" hidden></p>
                        </div>
                        <div class="social-field" data-platform="X/Twitter">
                            <label class="social-checkbox-label">
                                <input type="checkbox" class="social-checkbox" data-platform="X/Twitter" />
                                <span class="social-platform-name">X / Twitter</span>
                            </label>
                            <input type="url" class="input social-url" data-platform="X/Twitter" placeholder="https://x.com/yourname" autocomplete="off" />
                            <p class="field-error social-url-error" hidden></p>
                        </div>
                        <div class="social-field" data-platform="YouTube">
                            <label class="social-checkbox-label">
                                <input type="checkbox" class="social-checkbox" data-platform="YouTube" />
                                <span class="social-platform-name">YouTube</span>
                            </label>
                            <input type="url" class="input social-url" data-platform="YouTube" placeholder="https://youtube.com/@@yourchannel" autocomplete="off" />
                            <p class="field-error social-url-error" hidden></p>
                        </div>
                        <div class="social-field" data-platform="GitHub">
                            <label class="social-checkbox-label">
                                <input type="checkbox" class="social-checkbox" data-platform="GitHub" />
                                <span class="social-platform-name">GitHub</span>
                            </label>
                            <input type="url" class="input social-url" data-platform="GitHub" placeholder="https://github.com/yourname" autocomplete="off" />
                            <p class="field-error social-url-error" hidden></p>
                        </div>
                        <div class="social-field" data-platform="TikTok">
                            <label class="social-checkbox-label">
                                <input type="checkbox" class="social-checkbox" data-platform="TikTok" />
                                <span class="social-platform-name">TikTok</span>
                            </label>
                            <input type="url" class="input social-url" data-platform="TikTok" placeholder="https://tiktok.com/@@yourname" autocomplete="off" />
                            <p class="field-error social-url-error" hidden></p>
                        </div>
                    </div>
                </div>

                <!-- Retention period selector -->
                <div class="field-group">
                    <label class="field-label" for="retention-period">Retention period</label>
                    <div class="select-wrap">
                        <select id="retention-period" class="select">
                            <option value="1d">1 day</option>
                            <option value="7d" selected>7 days</option>
                            <option value="1m">1 month</option>
                            <option value="1y">1 year</option>
                            <option value="forever">Forever</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Customise block -->
            <div class="customise-block">
                <p class="section-label">Customise</p>

                <!-- Colors -->
                <div class="field-row">
                    <div class="field-group field-group--half">
                        <label class="field-label">Foreground</label>
                        <div class="color-picker-wrap" tabindex="0">
                            <input type="color" id="dark-color" class="color-input" value="#0d0d0d" />
                            <span class="color-swatch" id="dark-swatch"></span>
                            <span class="color-hex" id="dark-hex">#0d0d0d</span>
                        </div>
                    </div>
                    <div class="field-group field-group--half">
                        <label class="field-label">Background</label>
                        <div class="color-picker-wrap" tabindex="0">
                            <input type="color" id="light-color" class="color-input" value="#ffffff" />
                            <span class="color-swatch" id="light-swatch"></span>
                            <span class="color-hex" id="light-hex">#ffffff</span>
                        </div>
                    </div>
                </div>

                <!-- Size -->
                <div class="field-group">
                    <label class="field-label">
                        Module size
                        <span class="label-value" id="size-label">10 px</span>
                    </label>
                    <div class="range-wrap">
                        <span style="font-size:.7rem;color:var(--text-subtle)">S</span>
                        <input type="range" id="qr-size" class="range-input" min="5" max="20" value="10" />
                        <span style="font-size:.7rem;color:var(--text-subtle)">L</span>
                    </div>
                </div>

                <!-- Error correction -->
                <div class="field-group">
                    <label class="field-label" for="ecc-level">Error correction</label>
                    <div class="select-wrap">
                        <select id="ecc-level" class="select">
                            <option value="L">Low — 7% recovery</option>
                            <option value="M">Medium — 15% recovery</option>
                            <option value="Q">Quartile — 25% recovery</option>
                            <option value="H" selected>High — 30% recovery</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Logo block -->
            <div class="upload-block">
                <p class="section-label">Logo / Watermark</p>
                <div class="upload-zone" id="upload-zone">
                    <div class="upload-zone__inner" id="upload-inner">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                            <polyline points="17 8 12 3 7 8"/>
                            <line x1="12" y1="3" x2="12" y2="15"/>
                        </svg>
                        <span>Drop image or <strong>browse</strong></span>
                        <span class="upload-hint">PNG · JPG · SVG &nbsp;·&nbsp; max 2 MB</span>
                    </div>
                    <img class="upload-preview" id="logo-preview" alt="Logo preview" hidden />
                    <button class="upload-remove" id="remove-logo" hidden title="Remove">✕</button>
                    <input type="file" id="logo-file" accept="image/*" class="upload-file-input" />
                </div>

                <div class="logo-size-row" id="logo-size-row">
                    <label class="field-label" style="white-space:nowrap;margin:0">
                        Logo size &nbsp;<span class="label-value" id="logo-size-label">22%</span>
                    </label>
                    <input type="range" id="logo-size" class="range-input" min="5" max="30" value="22" />
                </div>
            </div>

        </div><!-- /sidebar-body -->
    </section>

    <!-- ── Output canvas ── -->
    <section class="panel--right">
        <div class="output-area" id="output-area">

            <!-- Placeholder -->
            <div class="output-placeholder" id="output-placeholder">
                <div class="ph-card">
                    <div class="ph-inner">
                        <svg class="ph-qr-icon" width="80" height="80" viewBox="0 0 32 32" fill="none">
                            <rect x="2" y="2" width="12" height="12" rx="2" fill="currentColor"/>
                            <rect x="18" y="2" width="12" height="12" rx="2" fill="currentColor"/>
                            <rect x="2" y="18" width="12" height="12" rx="2" fill="currentColor"/>
                            <rect x="18" y="18" width="5" height="5" rx="1" fill="currentColor"/>
                            <rect x="25" y="18" width="5" height="5" rx="1" fill="currentColor"/>
                            <rect x="18" y="25" width="5" height="5" rx="1" fill="currentColor"/>
                            <rect x="25" y="25" width="5" height="5" rx="1" fill="currentColor"/>
                            <rect x="5" y="5" width="6" height="6" rx="1" fill="white"/>
                            <rect x="21" y="5" width="6" height="6" rx="1" fill="white"/>
                            <rect x="5" y="21" width="6" height="6" rx="1" fill="white"/>
                        </svg>
                        <span class="ph-label">Enter a URL and generate</span>
                    </div>
                </div>
            </div>

            <!-- Result -->
            <div class="output-result" id="output-result" hidden>
                <!-- Single QR result (URL mode) -->
                <div class="qr-card" id="single-qr-card">
                    <div class="qr-card__image-wrap">
                        <img id="qr-image" alt="Generated QR code" />
                    </div>
                    <div class="qr-card__meta">
                        <span class="qr-card__url" id="qr-meta-url"></span>
                        <span class="qr-card__ecc" id="qr-meta-ecc"></span>
                    </div>
                </div>

                <!-- Contact QR grid (Contact mode) -->
                <div class="qr-grid" id="qr-grid" hidden>
                    <!-- Populated dynamically by JS -->
                </div>
                <div class="output-actions">
                    <button class="btn btn--outline" id="download-png">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                            <polyline points="7 10 12 15 17 10"/>
                            <line x1="12" y1="15" x2="12" y2="3"/>
                        </svg>
                        Download PNG
                    </button>
                    <button class="btn btn--outline" id="copy-btn">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                        </svg>
                        Copy
                    </button>
                    <button class="btn btn--outline" id="share-btn" hidden>
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
                            <polyline points="16 6 12 2 8 6"/>
                            <line x1="12" y1="2" x2="12" y2="15"/>
                        </svg>
                        Share
                    </button>
                    <button class="btn btn--outline" id="download-txt-btn" hidden>
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                            <line x1="16" y1="13" x2="8" y2="13"/>
                            <line x1="16" y1="17" x2="8" y2="17"/>
                        </svg>
                        Download TXT
                    </button>
                    <button class="btn btn--outline" id="share-vcf-btn" hidden>
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                        Share as VCF
                    </button>
                    <button class="btn btn--outline" id="share-link-btn" hidden>
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                        </svg>
                        Share Link
                    </button>
                    <button class="btn btn--danger-outline" id="delete-blob-btn" hidden>
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="3 6 5 6 21 6"/>
                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                        </svg>
                        Delete
                    </button>
                </div>

                <!-- Save/Drop prompt (Contact mode) -->
                <div class="save-prompt" id="save-prompt" hidden>
                    <div class="save-prompt__header">Save your contact data?</div>
                    <p class="save-prompt__desc">Enter an access code to save and share your contact data.</p>
                    <div class="field-group">
                        <label class="field-label" for="access-code-input">Access code</label>
                        <input id="access-code-input" type="password" class="input" placeholder="Enter access code" autocomplete="off" minlength="4" maxlength="6" />
                        <p class="field-error" id="access-code-error" hidden></p>
                    </div>
                    <div class="save-prompt__actions">
                        <button class="btn btn--primary" id="save-blob-btn">Save</button>
                    </div>
                    <p class="save-prompt__status" id="save-status" hidden></p>
                </div>

                <!-- Share fallback panel -->
                <div class="share-panel" id="share-panel" hidden>
                    <div class="share-panel__header">
                        <span>Share QR Code</span>
                        <button class="share-panel__close" id="share-panel-close" aria-label="Close share panel">&times;</button>
                    </div>
                    <div class="share-panel__grid">
                        <button class="share-channel" data-channel="email">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="22,4 12,13 2,4"/></svg>
                            <span>Email</span>
                        </button>
                        <button class="share-channel" data-channel="instagram">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
                            <span>Instagram</span>
                        </button>
                        <button class="share-channel" data-channel="telegram">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.2 4.4L2.4 10.8c-.6.2-.6 1.1 0 1.3l4.5 1.7 1.7 5.5c.1.4.6.6.9.3l2.5-2 4.9 3.6c.5.4 1.2.1 1.3-.5L21.8 5.4c.2-.7-.5-1.3-1.1-1z"/><line x1="9.5" y1="13.5" x2="21" y2="5"/></svg>
                            <span>Telegram</span>
                        </button>
                        <button class="share-channel" data-channel="whatsapp">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9L3 21"/><path d="M9 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1zm0 0c0 1.6 1.1 3.1 2.5 4 1.4.8 2.5.5 2.5.5l1-2-1.5-1-1 1c-.5 0-1.5-1-2-2l1-1-1-1.5-2 1z"/></svg>
                            <span>WhatsApp</span>
                        </button>
                        <button class="share-channel" data-channel="threema">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C6.48 2 2 5.58 2 10c0 2.13 1.06 4.04 2.75 5.44L3.5 21l4.28-2.14A11.29 11.29 0 0 0 12 19.5c5.52 0 10-3.36 10-7.5S17.52 2 12 2z"/><circle cx="8" cy="10" r="1.25" fill="currentColor" stroke="none"/><circle cx="12" cy="10" r="1.25" fill="currentColor" stroke="none"/><circle cx="16" cy="10" r="1.25" fill="currentColor" stroke="none"/></svg>
                            <span>Threema</span>
                        </button>
                        <button class="share-channel" data-channel="x">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                            <span>X</span>
                        </button>
                        <button class="share-channel" data-channel="facebook">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                            <span>Facebook</span>
                        </button>
                        <button class="share-channel" data-channel="linkedin">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                            <span>LinkedIn</span>
                        </button>
                        <button class="share-channel" data-channel="copy">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                            <span>Copy link</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Error -->
            <div class="output-error" id="output-error" hidden>
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <p id="error-text"></p>
            </div>

        </div>
    </section>

    <!-- ── Open Existing Contact Modal ── -->
    <div class="modal-backdrop" id="open-existing-backdrop" hidden>
        <div class="modal-dialog open-existing-modal">
            <div class="modal-dialog__header">Open Existing Contact</div>
            <div class="field-group">
                <label class="field-label" for="oe-first-name">First Name</label>
                <input id="oe-first-name" type="text" class="input" placeholder="Jane" autocomplete="off" />
            </div>
            <div class="field-group">
                <label class="field-label" for="oe-last-name">Last Name</label>
                <input id="oe-last-name" type="text" class="input" placeholder="Doe" autocomplete="off" />
            </div>
            <div class="field-group">
                <label class="field-label" for="oe-access-code">Access Code</label>
                <input id="oe-access-code" type="password" class="input" placeholder="Enter access code" autocomplete="off" minlength="4" maxlength="6" />
            </div>
            <p class="field-error" id="oe-error" hidden></p>
            <button class="btn btn--primary btn--full-width" id="oe-submit-btn">
                <span class="oe-btn__label">Open</span>
                <span class="oe-btn__spinner" hidden>
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                        <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="2"
                            stroke-dasharray="28" stroke-dashoffset="10" stroke-linecap="round"/>
                    </svg>
                </span>
            </button>
        </div>
    </div>

</main>
